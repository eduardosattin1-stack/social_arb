# PostgreSQL Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/social_radar

# NewsAPI (free tier: https://newsapi.org/register)
NEWS_API_KEY=your_newsapi_key_here

# Reddit API (create app: https://www.reddit.com/prefs/apps)
REDDIT_CLIENT_ID=your_reddit_client_id
REDDIT_CLIENT_SECRET=your_reddit_client_secret
REDDIT_USER_AGENT=SocialRadar/1.0

# YouTube Data API v3 (free tier: https://console.cloud.google.com/)
YOUTUBE_API_KEY=your_youtube_api_key

# LLM Budget (for entity resolution and signal narratives)
LLM_DAILY_TOKEN_BUDGET=50000
